<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestor de Pedidos</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; }
        .card { background: white; border-radius: 12px; shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
    </style>
</head>
<body class="p-4">
    <div class="max-w-full mx-auto">
        <header class="mb-6">
            <h1 class="text-2xl font-extrabold text-slate-900">📦 Gestor de Pedidos</h1>
            <p class="text-sm text-slate-600">Configura tu meta y calcula el pedido.</p>
        </header>

        <div class="space-y-6">
            <div class="card p-5 border-t-4 border-blue-500 shadow-sm">
                <h2 class="text-md font-bold mb-3">1. Agregar Producto</h2>
                <input type="text" id="p-nombre" class="w-full mb-2 p-3 border rounded-lg" placeholder="Nombre">
                <input type="number" id="p-meta" class="w-full mb-3 p-3 border rounded-lg" placeholder="Stock Ideal">
                <button onclick="addProd()" class="w-full bg-blue-600 text-white py-3 rounded-lg font-bold">Guardar Producto</button>
            </div>

            <div class="card p-5 shadow-sm">
                <h2 class="text-md font-bold mb-4">2. Conteo e Informe</h2>
                <div id="lista-tabla" class="space-y-4"></div>
                <div id="msg-vacio" class="text-center py-10 text-slate-400">Sin productos.</div>
                <button onclick="clearAll()" class="mt-6 text-xs text-red-400 block mx-auto">Borrar Base de Datos</button>
            </div>
        </div>
    </div>

<script>
    let db = JSON.parse(localStorage.getItem('app_inventario_v1')) || [];
    function addProd() {
        const n = document.getElementById('p-nombre').value.trim();
        const m = parseInt(document.getElementById('p-meta').value);
        if(!n || isNaN(m)) return alert("Completa los datos");
        db.push({ id: Date.now(), nombre: n, meta: m, actual: 0 });
        save();
        document.getElementById('p-nombre').value = '';
        document.getElementById('p-meta').value = '';
    }
    function updateStock(id, val) {
        const p = db.find(x => x.id === id);
        if(p) p.actual = parseInt(val) || 0;
        save();
    }
    function remove(id) {
        db = db.filter(x => x.id !== id);
        save();
    }
    function save() {
        localStorage.setItem('app_inventario_v1', JSON.stringify(db));
        render();
    }
    function render() {
        const t = document.getElementById('lista-tabla');
        const v = document.getElementById('msg-vacio');
        t.innerHTML = '';
        if(db.length === 0) v.style.display = 'block';
        else v.style.display = 'none';
        db.forEach(p => {
            const faltan = Math.max(0, p.meta - p.actual);
            t.innerHTML += `
                <div class="border-b pb-3">
                    <div class="flex justify-between items-start">
                        <span class="font-bold text-slate-700">${p.nombre} (Meta: ${p.meta})</span>
                        <button onclick="remove(${p.id})" class="text-xs text-red-500">X</button>
                    </div>
                    <div class="flex items-center mt-2 gap-4">
                        <div class="flex-1 text-sm">¿Cuántos hay?</div>
                        <input type="number" value="${p.actual}" oninput="updateStock(${p.id}, this.value)" 
                        class="w-20 p-2 border-2 border-blue-100 rounded text-center font-bold text-blue-700">
                        <div class="px-3 py-1 rounded-full text-xs font-bold ${faltan > 0 ? 'bg-orange-100 text-orange-600' : 'bg-green-100 text-green-600'}">
                            ${faltan > 0 ? 'Pedir ' + faltan : 'OK'}
                        </div>
                    </div>
                </div>`;
        });
    }
    function clearAll() { if(confirm("¿Borrar todo?")) { db = []; save(); } }
    render();
</script>
</body>
</html>
